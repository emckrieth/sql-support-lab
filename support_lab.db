import sqlite3
from pathlib import Path

DB_PATH = Path(__file__).resolve().parent.parent / "db" / "support_lab.db"

queries = {
    "failed_verifications": "SELECT verification_id, user_id, failure_reason, provider_latency_ms FROM verifications WHERE status = 'failed';",
    "duplicate_user_emails": "SELECT email, COUNT(*) AS cnt FROM users GROUP BY email HAVING COUNT(*) > 1;",
    "incident_signatures": "SELECT error_signature, COUNT(*) AS cnt FROM incidents GROUP BY error_signature ORDER BY cnt DESC;"
}

with sqlite3.connect(DB_PATH) as conn:
    for title, q in queries.items():
        print(f"\n## {title}")
        rows = conn.execute(q).fetchall()
        for row in rows:
            print(row)
